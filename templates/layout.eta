<!doctype html>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width,initial-scale=1" name="viewport" />
    <meta content="#333333" name="theme-color" />
    <link href="assets/favicon.ico" rel="icon" type="image/png">
    <link rel="stylesheet" href="./index.css" />
    <link rel="stylesheet" href="./pages.css" />
    <link rel="stylesheet" href="./collapsable.css" />
    <title><%= it.slug %> | Aron Edwards</title>
  </head>

  <picture>
    <source
      media="(max-width: 599)"
      srcset="./assets/Mountain_view_in_Robson_valley_mob.webp"
    />
    <source
      media="(min-width: 600)"
      srcset="./assets/Mountain_view_in_Robson_valley.webp"
    />
    <img
      alt="background"
      class="background-img"
      src="./assets/Mountain_view_in_Robson_valley.webp"
    />
  </picture>

  <body>
    <header>
      <nav>
        <ul class="active-<%= it.slug %>">
          <li><a href="./index.html">Home</a></li>
          <li><a href="./books.html">My Library</a></li>
          <li><a href="./quotations.html">Favourite Quotes</a></li>
          <li><a href="./projects.html">My Projects</a></li>
          <li><a href="./career.html">Career</a></li>
          <li><a href="./blog.html">Blog</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <article><%~ it.body %></article>

      <footer>© Aron Edwards 2026</footer>
    </main>
  </body>
</html>
